{
  "name": "doctor-mcp-cli",
  "version": "0.1.0",
  "description": "Diagnose MCP client configuration and stdio server startup problems.",
  "type": "module",
  "bin": {
    "doctor-mcp": "./dist/cli.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LSUFN/doctor-mcp-cli.git"
  },
  "bugs": {
